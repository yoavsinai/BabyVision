# =========================================================================
# BabyVision Configuration Example File (.env.example)
# Copy this to .env in the root directory and fill in your API keys.
# =========================================================================

# ----------------- OpenRouter / Model API Configuration -----------------
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# ----------------- MLLM Evaluation Configuration -----------------
# API Key for the model being evaluated. Usually the same as OPENROUTER_API_KEY.
MODEL_API_KEY="your-openrouter-api-key-here"
MODEL_BASE_URL="https://openrouter.ai/api/v1"

# The vision model to evaluate. Since the paper was published in January 2026,
# here are some of the latest free/low-cost multimodal models you can use:
# - google/gemini-2.5-flash:free
# - google/gemini-2.5-pro:free
# - meta-llama/llama-3.2-11b-vision-instruct:free
# - qwen/qwen-2-vl-7b-instruct:free
# - openrouter/free (automagically routes to a free vision/multimodal model)
MODEL_NAME="google/gemini-2.5-flash:free"

# API Key for the judge model. Usually the same as OPENROUTER_API_KEY.
JUDGE_API_KEY="your-openrouter-api-key-here"
JUDGE_BASE_URL="https://openrouter.ai/api/v1"

# The LLM judge model. We recommend using a high-quality free model like Llama 3.3 70B:
# - meta-llama/llama-3.3-70b-instruct:free
# - google/gemini-2.5-pro:free
JUDGE_MODEL_NAME="meta-llama/llama-3.3-70b-instruct:free"

# MLLM Execution parameters
# NOTE: Free models on OpenRouter have strict rate limits.
# We recommend lowering NUM_PROCESSES to 1 or 2 to avoid HTTP 429 errors.
NUM_PROCESSES=2
NUM_PASSES=3
TEST_JSON_PATH="../data/babyvision_data/meta_data.jsonl"
OUTPUT_DIR="./results"

# ----------------- Generation Evaluation Configuration -----------------
# (If you choose to run the image generation track)
# Available free/paid image generation models can be specified here.
GEN_MODEL_NAME="openai/gpt-4o" # Model generating annotation instructions
GEN_ROUNDS=3
